{
	"expo": {
		"name": "Notas Rápidas",
		"slug": "notas-rapidas",
		"version": "1.0.0",
		"orientation": "default",
		"platforms": ["android"],
		"backgroundColor": "#fafafa",
		"primaryColor": "#ff9800",
		"icon": "./assets/icon.png",
		"notification": {
			"icon": "./assets/icon-mono-small.png"
		},
		"userInterfaceStyle": "automatic",
		"newArchEnabled": true,
		"splash": {
			"image": "./assets/splash-icon.png",
			"resizeMode": "contain",
			"backgroundColor": "#ff9800"
		},
		"android": {
			"adaptiveIcon": {
				"foregroundImage": "./assets/adaptive-icon.png",
				"backgroundColor": "#ffffff"
			},
			"edgeToEdgeEnabled": true,
			"predictiveBackGestureEnabled": false,
			"permissions": ["READ_EXTERNAL_STORAGE"],
			"package": "com.renansantos7.notasrapidas",
			"userInterfaceStyle": "automatic"
		},
		"ios": {
			"bundleIdentifier": "com.renansantos7.notasrapidas"
		}
	}
}
