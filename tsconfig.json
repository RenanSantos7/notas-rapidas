{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "noUnusedLocals": false,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "strictNullChecks": false,
    "strict": true,
    "noUnusedParameters": false
  }
}
